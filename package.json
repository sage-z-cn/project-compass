{
  "name": "project-compass",
  "displayName": "Project Compass",
  "description": "%description%",
  "version": "1.0.0",
  "license": "GPL-3.0",
  "publisher": "sagez",
  "keywords": [
    "project compass",
    "project explorer",
    "project dock",
    "project",
    "explorer",
    "recent project",
    "recent folder",
    "Project Manager",
    "switch project",
    "项目管理",
    "最近项目"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sage-z-cn/project-compass.git"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "project-compass",
          "title": "%viewContainer.title%",
          "icon": "resources/sidebar.svg"
        }
      ]
    },
    "views": {
      "project-compass": [
        {
          "id": "project-compass.recent",
          "name": "%view.recent.name%",
          "icon": "resources/sidebar.svg",
          "type": "webview"
        },
        {
          "id": "project-compass.favorites",
          "name": "%view.favorites.name%",
          "icon": "resources/sidebar.svg",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "project-compass.openProject",
        "title": "%command.openProject%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "project-compass.addProject",
        "title": "%command.addProject%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "project-compass.gitClone",
        "title": "%command.gitClone%",
        "icon": "$(repo-clone)"
      },
      {
        "command": "project-compass.addGroup",
        "title": "%command.addGroup%",
        "icon": "$(new-folder)"
      },
      {
        "command": "project-compass.collapseAll",
        "title": "%command.collapseAll%",
        "icon": "$(collapse-all)"
      },
      {
        "command": "project-compass.expandAll",
        "title": "%command.expandAll%",
        "icon": "$(expand-all)"
      },
      {
        "command": "project-compass.addCurrentToFavorites",
        "title": "%command.addCurrentToFavorites%",
        "icon": "$(star-full)"
      },
      {
        "command": "project-compass.cleanInvalid",
        "title": "%command.cleanInvalid%",
        "icon": "$(trash)"
      },
      {
        "command": "project-compass.openSettings",
        "title": "%command.openSettings%",
        "icon": "$(gear)"
      },
      {
        "command": "project-compass.openInNewWindow",
        "title": "%command.openInNewWindow%"
      },
      {
        "command": "project-compass.openInCurrentWindow",
        "title": "%command.openInCurrentWindow%"
      },
      {
        "command": "project-compass.revealInExplorer",
        "title": "%command.revealInExplorer%"
      },
      {
        "command": "project-compass.addFavorite",
        "title": "%command.addFavorite%"
      },
      {
        "command": "project-compass.removeFavorite",
        "title": "%command.removeFavorite%"
      },
      {
        "command": "project-compass.renameProject",
        "title": "%command.renameProject%"
      },
      {
        "command": "project-compass.removeProject",
        "title": "%command.removeProject%"
      },
      {
        "command": "project-compass.renameGroup",
        "title": "%command.renameGroup%"
      },
      {
        "command": "project-compass.deleteGroup",
        "title": "%command.deleteGroup%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "project-compass.addCurrentToFavorites",
          "when": "false"
        },
        {
          "command": "project-compass.addGroup",
          "when": "false"
        },
        {
          "command": "project-compass.collapseAll",
          "when": "false"
        },
        {
          "command": "project-compass.expandAll",
          "when": "false"
        },
        {
          "command": "project-compass.openSettings",
          "when": "false"
        },
        {
          "command": "project-compass.openInNewWindow",
          "when": "false"
        },
        {
          "command": "project-compass.openInCurrentWindow",
          "when": "false"
        },
        {
          "command": "project-compass.revealInExplorer",
          "when": "false"
        },
        {
          "command": "project-compass.addFavorite",
          "when": "false"
        },
        {
          "command": "project-compass.removeFavorite",
          "when": "false"
        },
        {
          "command": "project-compass.renameProject",
          "when": "false"
        },
        {
          "command": "project-compass.removeProject",
          "when": "false"
        },
        {
          "command": "project-compass.renameGroup",
          "when": "false"
        },
        {
          "command": "project-compass.deleteGroup",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "project-compass.addProject",
          "when": "view == project-compass.recent",
          "group": "navigation@1"
        },
        {
          "command": "project-compass.gitClone",
          "when": "view == project-compass.recent",
          "group": "navigation@3"
        },
        {
          "command": "project-compass.addGroup",
          "when": "view == project-compass.favorites",
          "group": "navigation@1"
        },
        {
          "command": "project-compass.expandAll",
          "when": "view == project-compass.favorites",
          "group": "navigation@2"
        },
        {
          "command": "project-compass.collapseAll",
          "when": "view == project-compass.favorites",
          "group": "navigation@3"
        },
        {
          "command": "project-compass.addCurrentToFavorites",
          "when": "view == project-compass.favorites",
          "group": "navigation@0"
        },
        {
          "command": "project-compass.cleanInvalid",
          "when": "view == project-compass.recent",
          "group": "overflow@1"
        },
        {
          "command": "project-compass.cleanInvalid",
          "when": "view == project-compass.favorites",
          "group": "overflow@1"
        },
        {
          "command": "project-compass.openSettings",
          "when": "view == project-compass.recent",
          "group": "overflow@2"
        },
        {
          "command": "project-compass.openSettings",
          "when": "view == project-compass.favorites",
          "group": "overflow@2"
        }
      ],
      "view/item/context": [
        {
          "command": "project-compass.openInNewWindow",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "1_open@1"
        },
        {
          "command": "project-compass.openInCurrentWindow",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "1_open@2"
        },
        {
          "command": "project-compass.revealInExplorer",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "1_open@3"
        },
        {
          "command": "project-compass.addFavorite",
          "when": "viewItem =~ /^(project|project-invalid|recent-project|recent-project-invalid)$/",
          "group": "2_manage@1"
        },
        {
          "command": "project-compass.removeFavorite",
          "when": "viewItem =~ /^(project-fav|project-fav-invalid|favorite-project|favorite-project-invalid)$/",
          "group": "2_manage@1"
        },
        {
          "command": "project-compass.renameProject",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "2_manage@2"
        },
        {
          "command": "project-compass.removeProject",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "2_manage@3"
        },
        {
          "command": "project-compass.renameGroup",
          "when": "viewItem == group",
          "group": "1_manage@1"
        },
        {
          "command": "project-compass.deleteGroup",
          "when": "viewItem == group",
          "group": "1_manage@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "project-compass.openProject",
        "key": "alt+o",
        "mac": "alt+o"
      },
      {
        "command": "workbench.view.extension.project-compass",
        "key": "ctrl+alt+o",
        "mac": "ctrl+alt+o"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "projectCompass.recentProjectsLimit": {
          "type": "number",
          "default": 50,
          "description": "%config.recentProjectsLimit%"
        },
        "projectCompass.openProjectMode": {
          "type": "string",
          "default": "ask",
          "enum": [
            "ask",
            "currentWindow",
            "newWindow"
          ],
          "enumDescriptions": [
            "Ask each time",
            "Always open in current window",
            "Always open in new window"
          ],
          "description": "%config.openProjectMode%"
        },
        "projectCompass.openMode": {
          "type": "string",
          "default": "followIDE",
          "enum": [
            "singleClick",
            "doubleClick",
            "followIDE"
          ],
          "enumDescriptions": [
            "Single click to open",
            "Double click to open",
            "Follow IDE setting (workbench.list.openMode)"
          ],
          "description": "%config.openMode%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "vite build",
    "watch": "vite build --watch",
    "pack": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "devicon": "^2.17.0"
  }
}
