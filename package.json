{
  "name": "project-explorer",
  "displayName": "%viewContainer.title%",
  "description": "Auto-record projects, one-click switch. / 自动记录，一键即达。",
  "version": "0.0.1",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "project-explorer",
          "title": "%viewContainer.title%",
          "icon": "resources/sidebar.svg"
        }
      ]
    },
    "views": {
      "project-explorer": [
        {
          "id": "project-explorer.recent",
          "name": "%view.recent.name%",
          "icon": "resources/sidebar.svg",
          "type": "webview"
        },
        {
          "id": "project-explorer.favorites",
          "name": "%view.favorites.name%",
          "icon": "resources/sidebar.svg",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "project-explorer.openProject",
        "title": "%command.openProject%",
        "icon": "$(folder-opened)"
      },
      {
        "command": "project-explorer.addProject",
        "title": "%command.addProject%",
        "icon": "$(root-folder-opened)"
      },
      {
        "command": "project-explorer.gitClone",
        "title": "%command.gitClone%",
        "icon": "$(repo-clone)"
      },
      {
        "command": "project-explorer.addGroup",
        "title": "%command.addGroup%",
        "icon": "$(new-folder)"
      },
      {
        "command": "project-explorer.toggleCollapse",
        "title": "%command.toggleCollapse%",
        "icon": "$(collapse-all)"
      },
      {
        "command": "project-explorer.addCurrentToFavorites",
        "title": "%command.addCurrentToFavorites%",
        "icon": "$(star-full)"
      },
      {
        "command": "project-explorer.cleanInvalid",
        "title": "%command.cleanInvalid%",
        "icon": "$(trash)"
      },
      {
        "command": "project-explorer.openSettings",
        "title": "%command.openSettings%",
        "icon": "$(gear)"
      },
      {
        "command": "project-explorer.openInNewWindow",
        "title": "%command.openInNewWindow%"
      },
      {
        "command": "project-explorer.openInCurrentWindow",
        "title": "%command.openInCurrentWindow%"
      },
      {
        "command": "project-explorer.revealInExplorer",
        "title": "%command.revealInExplorer%"
      },
      {
        "command": "project-explorer.addFavorite",
        "title": "%command.addFavorite%"
      },
      {
        "command": "project-explorer.removeFavorite",
        "title": "%command.removeFavorite%"
      },
      {
        "command": "project-explorer.renameProject",
        "title": "%command.renameProject%"
      },
      {
        "command": "project-explorer.deleteProject",
        "title": "%command.deleteProject%"
      },
      {
        "command": "project-explorer.renameGroup",
        "title": "%command.renameGroup%"
      },
      {
        "command": "project-explorer.deleteGroup",
        "title": "%command.deleteGroup%"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "project-explorer.addGroup",
          "when": "false"
        },
        {
          "command": "project-explorer.toggleCollapse",
          "when": "false"
        },
        {
          "command": "project-explorer.openSettings",
          "when": "false"
        },
        {
          "command": "project-explorer.openInNewWindow",
          "when": "false"
        },
        {
          "command": "project-explorer.openInCurrentWindow",
          "when": "false"
        },
        {
          "command": "project-explorer.revealInExplorer",
          "when": "false"
        },
        {
          "command": "project-explorer.addFavorite",
          "when": "false"
        },
        {
          "command": "project-explorer.removeFavorite",
          "when": "false"
        },
        {
          "command": "project-explorer.renameProject",
          "when": "false"
        },
        {
          "command": "project-explorer.deleteProject",
          "when": "false"
        },
        {
          "command": "project-explorer.renameGroup",
          "when": "false"
        },
        {
          "command": "project-explorer.deleteGroup",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "project-explorer.addProject",
          "when": "view == project-explorer.recent",
          "group": "navigation@1"
        },
        {
          "command": "project-explorer.gitClone",
          "when": "view == project-explorer.recent",
          "group": "navigation@3"
        },
        {
          "command": "project-explorer.addGroup",
          "when": "view == project-explorer.favorites",
          "group": "navigation@1"
        },
        {
          "command": "project-explorer.toggleCollapse",
          "when": "view == project-explorer.favorites",
          "group": "navigation@2"
        },
        {
          "command": "project-explorer.addCurrentToFavorites",
          "when": "view == project-explorer.favorites",
          "group": "navigation@0"
        },
        {
          "command": "project-explorer.cleanInvalid",
          "when": "view == project-explorer.recent",
          "group": "overflow@1"
        },
        {
          "command": "project-explorer.cleanInvalid",
          "when": "view == project-explorer.favorites",
          "group": "overflow@1"
        },
        {
          "command": "project-explorer.openSettings",
          "when": "view == project-explorer.recent",
          "group": "overflow@2"
        },
        {
          "command": "project-explorer.openSettings",
          "when": "view == project-explorer.favorites",
          "group": "overflow@2"
        }
      ],
      "view/item/context": [
        {
          "command": "project-explorer.openInNewWindow",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "1_open@1"
        },
        {
          "command": "project-explorer.openInCurrentWindow",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "1_open@2"
        },
        {
          "command": "project-explorer.revealInExplorer",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "1_open@3"
        },
        {
          "command": "project-explorer.addFavorite",
          "when": "viewItem =~ /^(project|project-invalid|recent-project|recent-project-invalid)$/",
          "group": "2_manage@1"
        },
        {
          "command": "project-explorer.removeFavorite",
          "when": "viewItem =~ /^(project-fav|project-fav-invalid|favorite-project|favorite-project-invalid)$/",
          "group": "2_manage@1"
        },
        {
          "command": "project-explorer.renameProject",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "2_manage@2"
        },
        {
          "command": "project-explorer.deleteProject",
          "when": "viewItem =~ /^(project|project-invalid|project-fav|project-fav-invalid|favorite-project|favorite-project-invalid|recent-project|recent-project-invalid)$/",
          "group": "2_manage@3"
        },
        {
          "command": "project-explorer.renameGroup",
          "when": "viewItem == group",
          "group": "1_manage@1"
        },
        {
          "command": "project-explorer.deleteGroup",
          "when": "viewItem == group",
          "group": "1_manage@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "project-explorer.openProject",
        "key": "alt+o",
        "mac": "alt+o"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "projectExplorer.recentProjectsLimit": {
          "type": "number",
          "default": 20,
          "description": "%config.recentProjectsLimit%"
        },
        "projectExplorer.openProjectMode": {
          "type": "string",
          "default": "ask",
          "enum": [
            "ask",
            "currentWindow",
            "newWindow"
          ],
          "enumDescriptions": [
            "Ask each time",
            "Always open in current window",
            "Always open in new window"
          ],
          "description": "%config.openProjectMode%"
        },
        "projectExplorer.openMode": {
          "type": "string",
          "default": "followIDE",
          "enum": [
            "singleClick",
            "doubleClick",
            "followIDE"
          ],
          "enumDescriptions": [
            "Single click to open",
            "Double click to open",
            "Follow IDE setting (workbench.list.openMode)"
          ],
          "description": "%config.openMode%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "vite build",
    "watch": "vite build --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "devicon": "^2.17.0"
  }
}
